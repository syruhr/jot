{
  "manifest_version": 3,
  "name": "Jot",
  "description": "Quick capture for thoughts, todos, and focus",
  "version": "1.0.0",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": ["storage", "notifications", "alarms"]
}
